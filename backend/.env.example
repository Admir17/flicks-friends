# Local backend environment variables
# Copy this file to backend/.env and fill in your values.

# Required for movie API calls
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_TOKEN=your_tmdb_read_access_token_here

# Optional (watch party invite emails)
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here

# Recommended for local development so invite links target localhost
APP_BACKEND_BASE_URL=http://localhost:8080
